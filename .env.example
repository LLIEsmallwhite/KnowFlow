# ============================================================
# KnowFlow — 企业级 RAG 知识库问答助手 环境配置
# 复制此文件为 .env 并修改相应配置
# ============================================================

# ─── 应用基础 ───
APP_NAME=KnowFlow
APP_VERSION=0.1.0
DEBUG=true
SECRET_KEY=change-me-to-a-random-string
LOG_LEVEL=INFO

# ─── PostgreSQL ───
DB_HOST=localhost
DB_PORT=5432
DB_USER=knowflow
DB_PASSWORD=knowflow_secret
DB_NAME=knowflow

# ─── Redis ───
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ─── Milvus ───
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_COLLECTION_NAME=knowflow_knowledge

# ─── MinIO (对象存储) ───
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=knowflow-documents
MINIO_SECURE=false

# ─── LLM 配置 ───
# 对话模型
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o
LLM_API_KEY=sk-your-key-here
LLM_BASE_URL=https://api.openai.com/v1
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=4096

# 廉价模型（用于记忆压缩等轻量任务）
SUMMARY_LLM_MODEL=gpt-4o-mini
SUMMARY_LLM_TEMPERATURE=0.3

# ─── Embedding 模型 ───
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_API_KEY=sk-your-key-here
EMBEDDING_BASE_URL=https://api.openai.com/v1
EMBEDDING_DIMENSION=1024

# ─── Rerank 模型 ───
# 可选: cross-encoder/ms-marco-MiniLM-L-6-v2 (本地)
# 或 cohere/rerank-multilingual-v3.0 (API)
RERANK_PROVIDER=local
RERANK_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
RERANK_API_KEY=
RERANK_BASE_URL=

# ─── Langfuse 可观测性 (可选) ───
LANGFUSE_ENABLED=false
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# ─── 检索配置 ───
# RRF 基础参数
RRF_K=60
RRF_VECTOR_WEIGHT_BASE=0.7
RRF_KEYWORD_WEIGHT_BASE=0.3

# 检索阈值
VECTOR_SEARCH_TOP_K=50
KEYWORD_SEARCH_TOP_K=50
VECTOR_THRESHOLD=0.15
KEYWORD_THRESHOLD=0.30

# Rerank 配置
RERANK_TOP_K=10
RERANK_THRESHOLD=0.2

# ─── 记忆压缩配置 ───
MAX_CONTEXT_TOKENS=32000
MEMORY_CONSOLIDATION_THRESHOLD=0.5

# ─── Agent 配置 ───
AGENT_MAX_ITERATIONS=10
AGENT_PARALLEL_TOOL_CALLS=true
AGENT_LLM_TIMEOUT=120

# ─── Web Search ───
WEB_SEARCH_ENABLED=false
WEB_SEARCH_PROVIDER=duckduckgo

# ─── Celery ───
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
